{
  "name": "brick-factory-crm-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "set \"NODE_PATH=%CD%\\node_modules\" && node --max-old-space-size=6144 node_modules/next/dist/bin/next dev --port 3001",
    "build": "node --max-old-space-size=1024 node_modules/next/dist/bin/next build",
    "build:desktop": "set \"NEXT_PUBLIC_API_URL=http://185.191.141.138/api\" && npm run build && electron-builder --win nsis",
    "desktop": "set \"NEXT_PUBLIC_API_URL=http://185.191.141.138/api\" && npm run build && electron .",
    "start": "next start --port 3001",
    "lint": "next lint"
  },
  "build": {
    "appId": "uz.gishtzavodi.crm",
    "productName": "Gisht Zavodi CRM",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      ".next/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.ts",
      "public/**/*"
    ],
    "asar": false,
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "next": "^15.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "axios": "^1.7.9",
    "@tanstack/react-query": "^5.62.16",
    "@tanstack/react-query-devtools": "^5.62.16",
    "react-hook-form": "^7.54.2",
    "@hookform/resolvers": "^3.9.1",
    "zod": "^3.24.1",
    "recharts": "^2.13.3",
    "lucide-react": "^0.468.0",
    "sonner": "^1.7.1",
    "next-themes": "^0.4.4",
    "date-fns": "^4.1.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "class-variance-authority": "^0.7.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.2"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "eslint": "^9",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint-config-next": "^15.5.0"
  }
}
