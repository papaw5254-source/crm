# Server
PORT=3000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
DB_DATABASE=brick_factory_crm

# JWT — use long random strings in production
JWT_SECRET=CHANGE_ME_USE_RANDOM_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_RANDOM_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10
